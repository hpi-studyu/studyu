{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studyu.app/schemas/study-protocol-authoring.json",
  "title": "StudyU Protocol Authoring Schema",
  "description": "Structured authoring schema for StudyU study definitions that use deterministic handles instead of UUIDs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "description",
    "icon_name",
    "contact",
    "screening",
    "questionnaire",
    "eligibility_criteria",
    "interventions",
    "observations",
    "schedule",
    "consent"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "$id": {
      "type": "string",
      "format": "uri"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "icon_name": {
      "type": "string",
      "minLength": 1
    },
    "contact": {
      "$ref": "#/$defs/contact"
    },
    "screening": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participation_mode",
        "questionnaire_ref",
        "result_sharing"
      ],
      "properties": {
        "participation_mode": {
          "type": "string",
          "enum": [
            "open",
            "invite"
          ]
        },
        "questionnaire_ref": {
          "$ref": "#/$defs/handle"
        },
        "result_sharing": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "organization"
          ]
        }
      }
    },
    "questionnaire": {
      "$ref": "#/$defs/questionnaire"
    },
    "eligibility_criteria": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/eligibilityCriterion"
      }
    },
    "interventions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/intervention"
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation"
      }
    },
    "schedule": {
      "$ref": "#/$defs/studySchedule"
    },
    "consent": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/consentItem"
      }
    }
  },
  "$defs": {
    "handle": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
      "description": "Deterministic identifier handle (e.g., screening_q1, intervention_1_task_1)."
    },
    "timeOfDay": {
      "type": "string",
      "pattern": "^(?:[01]?\\d|2[0-3]):[0-5]\\d$",
      "description": "24 hour time formatted as HH:mm."
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization",
        "email",
        "website",
        "phone"
      ],
      "properties": {
        "organization": {
          "type": "string",
          "minLength": 1
        },
        "institutionalReviewBoard": {
          "type": "string"
        },
        "institutionalReviewBoardNumber": {
          "type": "string"
        },
        "researchers": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "website": {
          "type": "string",
          "format": "uri"
        },
        "phone": {
          "type": "string"
        },
        "additionalInfo": {
          "type": "string"
        }
      }
    },
    "questionnaire": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "questions"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/handle"
        },
        "title": {
          "type": "string"
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/question"
          }
        }
      }
    },
    "question": {
      "oneOf": [
        {
          "$ref": "#/$defs/questionBoolean"
        },
        {
          "$ref": "#/$defs/questionChoice"
        },
        {
          "$ref": "#/$defs/questionScale"
        },
        {
          "$ref": "#/$defs/questionAnnotatedScale"
        },
        {
          "$ref": "#/$defs/questionVisualAnalogue"
        },
        {
          "$ref": "#/$defs/questionFreeText"
        },
        {
          "$ref": "#/$defs/questionImage"
        },
        {
          "$ref": "#/$defs/questionAudio"
        },
        {
          "$ref": "#/$defs/questionPain"
        },
        {
          "$ref": "#/$defs/questionFitbit"
        }
      ]
    },
    "questionBase": {
      "type": "object",
      "required": [
        "type",
        "id",
        "prompt"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "$ref": "#/$defs/handle"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "questionBoolean": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "boolean"
            }
          }
        }
      ]
    },
    "questionChoice": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "required": [
            "choices"
          ],
          "properties": {
            "type": {
              "const": "choice"
            },
            "multiple": {
              "type": "boolean"
            },
            "choices": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/choiceOption"
              }
            }
          }
        }
      ]
    },
    "questionScale": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "$ref": "#/$defs/sliderQuestionCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "scale"
            },
            "annotations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/scaleAnnotation"
              }
            },
            "min_color": {
              "type": "integer"
            },
            "max_color": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "questionAnnotatedScale": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "$ref": "#/$defs/sliderQuestionCommon"
        },
        {
          "type": "object",
          "required": [
            "type",
            "annotations"
          ],
          "properties": {
            "type": {
              "const": "annotatedScale"
            },
            "annotations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/scaleAnnotation"
              }
            }
          }
        }
      ]
    },
    "questionVisualAnalogue": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "$ref": "#/$defs/sliderQuestionCommon"
        },
        {
          "type": "object",
          "required": [
            "type",
            "minimumAnnotation",
            "maximumAnnotation",
            "minimumColor",
            "maximumColor"
          ],
          "properties": {
            "type": {
              "const": "visualAnalogue"
            },
            "minimumAnnotation": {
              "type": "string"
            },
            "maximumAnnotation": {
              "type": "string"
            },
            "minimumColor": {
              "type": "integer"
            },
            "maximumColor": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "questionFreeText": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "required": [
            "type",
            "lengthRange",
            "textType"
          ],
          "properties": {
            "type": {
              "const": "freeText"
            },
            "lengthRange": {
              "type": "array",
              "prefixItems": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "integer",
                  "minimum": 0
                }
              ],
              "minItems": 2,
              "maxItems": 2
            },
            "textType": {
              "type": "string",
              "enum": [
                "any",
                "alphanumeric",
                "numeric",
                "custom"
              ]
            },
            "customTypeExpression": {
              "type": "string"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "textType": {
                    "const": "custom"
                  }
                }
              },
              "then": {
                "required": [
                  "customTypeExpression"
                ]
              }
            }
          ]
        }
      ]
    },
    "questionImage": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "ImageCapturingQuestion"
            }
          }
        }
      ]
    },
    "questionAudio": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "required": [
            "maxRecordingDurationSeconds"
          ],
          "properties": {
            "type": {
              "const": "AudioRecordingQuestion"
            },
            "maxRecordingDurationSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      ]
    },
    "questionPain": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "pain"
            }
          }
        }
      ]
    },
    "questionFitbit": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "required": [
            "types"
          ],
          "properties": {
            "type": {
              "const": "FitbitQuestion"
            },
            "types": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "heartrate",
                  "sleep",
                  "steps"
                ]
              },
              "uniqueItems": true
            }
          }
        }
      ]
    },
    "sliderQuestionCommon": {
      "type": "object",
      "required": [
        "minimum",
        "maximum"
      ],
      "properties": {
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "initial": {
          "type": "number"
        },
        "step": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "scaleAnnotation": {
      "type": "object",
      "required": [
        "value",
        "annotation"
      ],
      "properties": {
        "value": {
          "type": "integer"
        },
        "annotation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "choiceOption": {
      "type": "object",
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/handle"
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "eligibilityCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/expression"
        }
      }
    },
    "expression": {
      "oneOf": [
        {
          "$ref": "#/$defs/expressionBoolean"
        },
        {
          "$ref": "#/$defs/expressionChoice"
        },
        {
          "$ref": "#/$defs/expressionNumeric"
        },
        {
          "$ref": "#/$defs/expressionText"
        },
        {
          "$ref": "#/$defs/expressionNot"
        },
        {
          "$ref": "#/$defs/expressionComposite"
        }
      ]
    },
    "expressionBase": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        }
      }
    },
    "expressionValueBase": {
      "allOf": [
        {
          "$ref": "#/$defs/expressionBase"
        },
        {
          "type": "object",
          "required": [
            "target"
          ],
          "properties": {
            "target": {
              "$ref": "#/$defs/handle"
            }
          }
        }
      ]
    },
    "expressionBoolean": {
      "allOf": [
        {
          "$ref": "#/$defs/expressionValueBase"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "boolean"
            }
          }
        }
      ]
    },
    "expressionChoice": {
      "allOf": [
        {
          "$ref": "#/$defs/expressionValueBase"
        },
        {
          "type": "object",
          "required": [
            "choices"
          ],
          "properties": {
            "type": {
              "const": "choice"
            },
            "choices": {
              "type": "array",
              "items": {
                "type": [
                  "string",
                  "number",
                  "boolean"
                ]
              }
            }
          }
        }
      ]
    },
    "expressionNumeric": {
      "allOf": [
        {
          "$ref": "#/$defs/expressionValueBase"
        },
        {
          "type": "object",
          "required": [
            "comparator",
            "value"
          ],
          "properties": {
            "type": {
              "const": "numeric"
            },
            "comparator": {
              "type": "string",
              "enum": [
                "=",
                "!=",
                ">",
                "<",
                ">=",
                "<="
              ]
            },
            "value": {
              "type": "number"
            }
          }
        }
      ]
    },
    "expressionText": {
      "allOf": [
        {
          "$ref": "#/$defs/expressionValueBase"
        },
        {
          "type": "object",
          "required": [
            "comparator",
            "value"
          ],
          "properties": {
            "type": {
              "const": "text"
            },
            "comparator": {
              "type": "string",
              "enum": [
                "=",
                "!=",
                "contains",
                "does_not_contain"
              ]
            },
            "value": {
              "type": "string"
            }
          }
        }
      ]
    },
    "expressionNot": {
      "allOf": [
        {
          "$ref": "#/$defs/expressionBase"
        },
        {
          "type": "object",
          "required": [
            "expression"
          ],
          "properties": {
            "type": {
              "const": "not"
            },
            "expression": {
              "$ref": "#/$defs/expression"
            }
          }
        }
      ]
    },
    "expressionComposite": {
      "allOf": [
        {
          "$ref": "#/$defs/expressionBase"
        },
        {
          "type": "object",
          "required": [
            "logicType",
            "expressions"
          ],
          "properties": {
            "type": {
              "const": "composite"
            },
            "logicType": {
              "type": "string",
              "enum": [
                "and",
                "or"
              ]
            },
            "expressions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        }
      ]
    },
    "intervention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "icon",
        "tasks"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/handle"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checkmarkTask"
          }
        }
      }
    },
    "checkmarkTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id",
        "title",
        "schedule"
      ],
      "properties": {
        "type": {
          "const": "checkmark"
        },
        "id": {
          "$ref": "#/$defs/handle"
        },
        "title": {
          "type": "string"
        },
        "header": {
          "type": "string"
        },
        "footer": {
          "type": "string"
        },
        "schedule": {
          "$ref": "#/$defs/taskSchedule"
        }
      }
    },
    "taskSchedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completionPeriods",
        "reminders"
      ],
      "properties": {
        "completionPeriods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/completionPeriod"
          }
        },
        "reminders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timeOfDay"
          }
        }
      }
    },
    "completionPeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unlockTime",
        "lockTime"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/handle"
        },
        "unlockTime": {
          "$ref": "#/$defs/timeOfDay"
        },
        "lockTime": {
          "$ref": "#/$defs/timeOfDay"
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id",
        "title",
        "schedule"
      ],
      "properties": {
        "type": {
          "const": "questionnaire"
        },
        "id": {
          "$ref": "#/$defs/handle"
        },
        "title": {
          "type": "string"
        },
        "header": {
          "type": "string"
        },
        "footer": {
          "type": "string"
        },
        "schedule": {
          "$ref": "#/$defs/taskSchedule"
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/question"
          }
        }
      }
    },
    "studySchedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "numberOfCycles",
        "phaseDuration",
        "includeBaseline",
        "sequence",
        "sequenceCustom"
      ],
      "properties": {
        "numberOfCycles": {
          "type": "integer",
          "minimum": 1
        },
        "phaseDuration": {
          "type": "integer",
          "minimum": 1
        },
        "includeBaseline": {
          "type": "boolean"
        },
        "sequence": {
          "type": "string",
          "enum": [
            "alternating",
            "counterBalanced",
            "randomized",
            "customized"
          ]
        },
        "sequenceCustom": {
          "type": "string",
          "pattern": "^[A-Za-z]+$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "sequence": {
                "const": "customized"
              }
            }
          },
          "then": {
            "properties": {
              "sequenceCustom": {
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "sequence": {
                "const": "customized"
              }
            }
          },
          "else": {
            "properties": {
              "sequenceCustom": {
                "const": "ABAB"
              }
            }
          }
        }
      ]
    },
    "consentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "iconName"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/handle"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "iconName": {
          "type": "string"
        }
      }
    }
  }
}
